APP_NAME=Certalytic
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# In production, set this to your public HTTPS URL (e.g. https://app.example.com).

TRUSTED_PROXIES=*

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=secret

# Redis Configuration
QUEUE_CONNECTION=redis
CACHE_STORE=redis
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log

# S3 / Local MinIO Storage
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=local_admin
AWS_SECRET_ACCESS_KEY=local_password123
AWS_DEFAULT_REGION=eu-west-1
AWS_BUCKET=certalytic-local
AWS_ENDPOINT=http://127.0.0.1:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# Miscellaneous Drivers
MEMCACHED_HOST=127.0.0.1
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# AI Processing (Mistral EU Only)
MISTRAL_API_KEY=
MISTRAL_BASE_URL=https://api.mistral.ai/v1
MISTRAL_OCR_MODEL=mistral-ocr-latest
MISTRAL_CHAT_MODEL=mistral-small-latest
MISTRAL_TRANSCRIPTION_MODEL=voxtral-mini-latest
MISTRAL_TIMEOUT=120
MISTRAL_TRANSCRIPTION_TIMEOUT=600

# Billing (Stripe Cashier)
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
CASHIER_CURRENCY=usd
CASHIER_CURRENCY_LOCALE=en_US
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_SCALE=
STRIPE_PRICE_PACK_QUICK=
STRIPE_PRICE_PACK_SURGE=
STRIPE_PRICE_PACK_BOOST=
# One-time price for a pack of 5 transcription tokens
STRIPE_PRICE_TRANSCRIPT_FIVE_PACK=

# Application Queues
CERTALYTIC_QUEUE=default
CERTALYTIC_PRIORITY_QUEUE=screenings-priority
CERTALYTIC_TRANSCRIPTIONS_QUEUE=transcriptions
CERTALYTIC_SIGNED_URL_TTL=15
CERTALYTIC_CV_MAX_KB=5120
CERTALYTIC_TRANSCRIPT_FILE_MAX_KB=5120
CERTALYTIC_AUDIO_MAX_KB=102400
# PHP upload_max_filesize and post_max_size must exceed CERTALYTIC_AUDIO_MAX_KB (see php/uploads.ini).
CERTALYTIC_AUDIO_MAX_MINUTES=60
CERTALYTIC_MISTRAL_MAX_INPUT_TOKENS=128000
CERTALYTIC_MAX_TEAMS_PER_USER=3
CERTALYTIC_RATE_LIMIT_LOGIN=10
CERTALYTIC_RATE_LIMIT_REGISTER=5
CERTALYTIC_RATE_LIMIT_PASSWORD_RESET=5
CERTALYTIC_RATE_LIMIT_AUTHENTICATED=120
CERTALYTIC_RATE_LIMIT_SCREENING=10
CERTALYTIC_RATE_LIMIT_TRANSCRIPTION=5

CERTALYTIC_RATE_LIMIT_TRANSCRIPTION=5

CERTALYTIC_COMPANY_LEGAL_NAME="Certalytic GmbH"
CERTALYTIC_COMPANY_ADDRESS="Musterstraße 1"
CERTALYTIC_COMPANY_ZIP="10115"
CERTALYTIC_COMPANY_CITY="Berlin"
CERTALYTIC_COMPANY_COUNTRY="Germany"
CERTALYTIC_COMPANY_PHONE="+49 30 12345678"
CERTALYTIC_COMPANY_EMAIL="hello@certalytic.com"
CERTALYTIC_COMPANY_REG_NUMBER="HRB 000000"
CERTALYTIC_COMPANY_VAT_ID="DE000000000"
CERTALYTIC_COMPANY_DIRECTOR="Managing Director"
CERTALYTIC_SOCIAL_LINKEDIN="https://linkedin.com/company/certalytic"
CERTALYTIC_SOCIAL_GITHUB="https://github.com/certalytic"
CERTALYTIC_SOCIAL_X="https://x.com/certalytic"

CERTALYTIC_MARKETING_CANDIDATES_SCREENED="12,400+"
CERTALYTIC_MARKETING_CUSTOMERS="180+"
CERTALYTIC_MARKETING_COUNTRIES="14"
CERTALYTIC_MARKETING_AUDIO_HOURS="2,800+"
CERTALYTIC_MARKETING_SAVED_MILLIONS="€4.2M"

VITE_APP_NAME="${APP_NAME}"