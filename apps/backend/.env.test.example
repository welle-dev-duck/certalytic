# E2E test environment (copy to .env.test)
NODE_ENV=test
PORT=3000

BASE_URL=http://localhost:3000
WEB_APP_URL=http://localhost:3001

# Use a dedicated database. Create it first:
#   createdb postgres_test
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres_test

# Use a separate Redis logical DB from development.
REDIS_URL=redis://localhost:6379/1

STRIPE_SECRET_KEY=sk_test_mock
STRIPE_WEBHOOK_SECRET=whsec_mock

# Only for local fallback when using the shared dev database.
# E2E_ALLOW_SHARED_DB=true
