# Server
PORT=3000
NODE_ENV=development

# API (better-auth base URL — must match what the web app calls)
BASE_URL=http://localhost:3000

# Frontend (trusted origin for CORS / cookies)
WEB_APP_URL=http://localhost:3001

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_SCALE=
STRIPE_PRICE_PACK_QUICK=
STRIPE_PRICE_PACK_SURGE=
STRIPE_PRICE_PACK_BOOST=

# Mistral (chat + OCR — transcription not ported)
MISTRAL_API_KEY=
MISTRAL_BASE_URL=https://api.mistral.ai/v1
MISTRAL_OCR_MODEL=mistral-ocr-latest
MISTRAL_CHAT_MODEL=mistral-small-latest
MISTRAL_TIMEOUT=120

# S3 / MinIO storage
AWS_ACCESS_KEY_ID=local_admin
AWS_SECRET_ACCESS_KEY=local_password123
AWS_DEFAULT_REGION=eu-west-1
AWS_BUCKET=certalytic-local
AWS_ENDPOINT=http://127.0.0.1:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# Product limits
CERTALYTIC_SIGNED_URL_TTL=15
CERTALYTIC_CV_MAX_KB=5120
CERTALYTIC_TRANSCRIPT_FILE_MAX_KB=5120
CERTALYTIC_MISTRAL_MAX_INPUT_TOKENS=128000
CERTALYTIC_MAX_TEAMS_PER_USER=3
CERTALYTIC_RATE_LIMIT_LOGIN=10
CERTALYTIC_RATE_LIMIT_REGISTER=5
CERTALYTIC_RATE_LIMIT_PASSWORD_RESET=5
CERTALYTIC_RATE_LIMIT_AUTHENTICATED=120
CERTALYTIC_RATE_LIMIT_SCREENING=10
CERTALYTIC_QUEUE=default
CERTALYTIC_PRIORITY_QUEUE=screenings-priority

# Company / legal (public config API)
CERTALYTIC_COMPANY_LEGAL_NAME="Certalytic GmbH"
CERTALYTIC_COMPANY_ADDRESS="Musterstraße 1"
CERTALYTIC_COMPANY_ZIP="10115"
CERTALYTIC_COMPANY_CITY="Berlin"
CERTALYTIC_COMPANY_COUNTRY="Germany"
CERTALYTIC_COMPANY_PHONE="+49 30 12345678"
CERTALYTIC_COMPANY_EMAIL="hello@certalytic.com"
CERTALYTIC_COMPANY_REG_NUMBER="HRB 000000"
CERTALYTIC_COMPANY_VAT_ID="DE000000000"
CERTALYTIC_COMPANY_DIRECTOR="Managing Director"
CERTALYTIC_SOCIAL_LINKEDIN="https://linkedin.com/company/certalytic"
CERTALYTIC_SOCIAL_GITHUB="https://github.com/certalytic"
CERTALYTIC_SOCIAL_X="https://x.com/certalytic"

# Marketing stats (public config API)
CERTALYTIC_MARKETING_CANDIDATES_SCREENED="12,400+"
CERTALYTIC_MARKETING_CUSTOMERS="180+"
CERTALYTIC_MARKETING_COUNTRIES="14"
CERTALYTIC_MARKETING_SAVED_MILLIONS="€4.2M"
